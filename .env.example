# Azure AI Foundry / Microsoft Foundry Configuration
# Copy this file to .env and replace placeholder values with your real Azure values.
# Never commit your real .env file to GitHub.

AZURE_AI_PROJECT_ENDPOINT=your_project_endpoint_here
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# Optional settings if using subscription/resource group based configuration
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_RESOURCE_GROUP=your_resource_group_here
AZURE_AI_PROJECT_NAME=your_project_name_here

# Application settings
APP_ENV=development
USE_AZURE_AI=false